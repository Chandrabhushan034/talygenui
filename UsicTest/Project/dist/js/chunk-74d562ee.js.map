<template>
  <div class="my-popups">
    <loader :is-visible="isLoading"></loader>
    <div class="modal d-block">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header theme-primary partition-full d-flex">
            <h4 class="modal-title">{{ userName }} - {{ DepartmentName }}</h4>
            <button type="button" class="close" v-on:click="Close">
              <em class="fa fa-times" aria-hidden="true"></em>
            </button>
          </div>
          <div class="modal-body">
            <dynamic-form ref="AddTaskOnCell" lang="en" :buttons="buttons" :schema="FormSchema"
              :mandatorytext="MandatoryString" v-on:OnSubmit="OnSubmit">
              <template v-slot:tgslot-Hours="{ data }">
                <div>
                  <input type="text" class="form-control" @keypress="restrictToNumbers($event)" v-model="Hours"
                    @blur="validateHours" />
                  <span name="Hours" class="invalid-feedback d-block">{{ data.error }}</span>
                  <div v-if="hoursError" class="error-message text-danger">
                    {{ $t('Pleaseenteravalue') }}
                  </div>
                </div>
              </template>
              <template v-slot:tgslot-TaskDescription="{ data }">
                <div class="row">
                  <div class="col-lg-12 mb-3" id="divshowoffDaysCalendar">
                    <div class="form-group offdayscalendar">
                      <div class="off_day_container" style="height: 272px;">
                      <div class="off_day_left">
                          <div class="off_day_leftmain monthclick monthFeb2026" data-month="1" data-year="2026">
                            <p style="margin: 0px; float: left; width: 84%;">{{ currentMonthName }} {{ currentYear
                              }}<span id="spnFeb2026"
                                style="display: block; font-size: 11px; line-height: 19px; color:#878787; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
                                data-off-days="1" title="Working On Off days: 1">Working On Off days: {{
                                selectedWorkingDays }}</span>
                            </p>
                            <div class="off_day_leftmainChk">
                              <input type="checkbox" value="all" name="Feb2026" id="Feb2026"
                                style="display: none;"><label for="Feb2026"> </label>
                            </div>
                          </div>
                        </div>
                        <div class="off_day_calender" style="top: 10px; height: 232px;">

                          <div class="off_day_calenderHeader">
                            {{ currentMonthName }} {{ currentYear }}
                          </div>

                          <div class="off_day_calenderdays">
                            <div v-for="day in weekDays" :key="day" class="off_day_calenderday">
                              {{ day }}
                            </div>
                          </div>
                          <div class="off_day_calenderdates">
                            <div v-for="(item, index) in calendarDays" :key="index" class="off_day_calenderdate"
                              style="width:14.28%; cursor:pointer;" :class="{
                                selected: item && item.selected,
                                empty: !item,
                                disabled: item && !isWeekend(item.day)
                              }" @click="item && onDayClick(item)">
                              {{ item ? item.day : '' }}
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </template>
              <template v-slot:tgslot-HoursFrom="{ data }">
                <VueTimepicker auto-scroll v-model="startHour" @open="dropdownStatus = 'opened'" format="hh:mm A"
                  label="Time Per Day" drop-direction="auto" container-id="auto-dropdown-containter"
                  input-class="form-control"></VueTimepicker>
              </template>
              <template v-slot:tgslot-HoursTo="{ data }">
                <VueTimepicker auto-scroll v-model="endHour" @close="dropdownStatus = 'closed'" format="hh:mm A"
                  label="Time Per Day" drop-direction="auto" container-id="auto-dropdown-containter"
                  input-class="form-control"></VueTimepicker>
              </template>
            </dynamic-form>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import VueTimepicker from 'vue2-timepicker';
import 'vue2-timepicker/dist/VueTimepicker.css';
import DataService from '../../../services/DataService.js';

export default {
  components: { VueTimepicker },
  props: {
    CellData: {
      type: Array | Object
    }
  },
  data() {
    return {
      MandatoryString:'Fields marked with an asterisk (*) are mandatory.',
      Descriptionn: '',
      Hours: 9,
      isLoading:false,
      hoursError:false,
      startHour: this.getCurrentTime(),
      endHour: this.getCurrentTime(),
      FormSchema: [
        {
          layoutType: "double",
          Data: [
            {
              astype: "MultiSelectField",
              label: this.$t('Select Project'),
              name: "project",
              multiple: false,
              mode: "project",
              value: "",
              config: {
                options: [],
                onChange: this.onProjectChange
              },
              disabled: false,
              placeholder: this.$t('Select Project'),
              validationRules: { "required": true, max: 100 }
            },
            {
              astype: "MultiSelectField",
              label: this.$t('Task'),
              mode: "task",
              multiple: false,
              name: "task",
              value: "",
              config: {
                options: []
              },
              disabled: false,
              placeholder: this.$t('Select Task'),
              validationRules: { "required": true, max: 100 }
            },
            {
              astype: "DateField",
              label: this.$t("From"),
              name: "planned_end_date",
              value: '',
              placeholder: this.$t("From"),
              visibility: true,
              validationRules: { required: true },
              config: { mode: "date", format: "M/D/YYYY", minDate: '', maxDate: '', onChange: this.checkEndMinDate }
            },
            {
              astype: "DateField",
              label: this.$t('To'),
              name: "planned_start_date",
              value: '',
              visibility: true,
              validationRules: { "required": true },
              config: { mode: "date", format: "M/D/YYYY", minDate: '', maxDate: '' }
            },
            {
              astype: "RadioField",
              label: "Type",
              name: "Type",
              value: '0',
              placeholder: "",
              config: {
                options: [
                  { value: "0", name: "Book Hours Per Day" },
                  { value: "1", name: "Book specific time" }
                ],
                onChange: this.OnTimeFiledEnabledChange
              },
              validationRules: { "required": true },
            }
          ]
        },
        {
          layoutType: "double",
          Data: [
            {
              astype: "SlotField",
              label: this.$t('Hours Per Day'),
              name: "Hours",
              value: "00",
              placeholder: "",
              validationRules: { required: true },
              visibility: true
            },
            {
              astype: "SlotField",
              label: this.$t('Time Per Day'),
              name: "HoursFrom",
              value: "00",
              placeholder: "",
              // validationRules: { required: true },
              visibility: false
            },
            {
              astype: "SlotField",
              label: this.$t('To'),
              name: "HoursTo",
              value: "00",
              placeholder: "",
              // validationRules: { required: true, max: 24 },
              visibility: false
            }
          ]
        },
        {
          layoutType: "double",
          Data: [
            {
              astype: "RadioField",
              label: this.$t('Working On Off days'),
              name: "WorkingOnOffdays",
              value: 'No',
              placeholder: "",
              config: {
                options: [
                  { value: "Yes", name: "Yes" },
                  { value: "No", name: "No" }
                ],
                onChange: this.OnWorkDaydEnabledChange
              },
              validationRules: "required"
            },
            {
              astype: "RadioField",
              label: "Task Type",
              name: "TaskType",
              value: '0',
              placeholder: "",
              config: {
                options: [
                  { value: "0", name: "Fixed" },
                  { value: "1", name: "Optional" }
                ]
              },
              validationRules: "required"
            }
          ]
        },
        {
          layoutType: "single",
          Data: [
            {
              astype: "SlotField",
              label: this.$t('TaskDescription'),
              name: "TaskDescription",
              value: "",
              validationRules: { "required": false, max: 4000 },
              visibility: false,
              config: { rows: 3 }
            },
            {
              astype: "TextAreaField",
              label: this.$t('Description'),
              name: "Description",
              value: "",
              validationRules: { "required": false, max: 4000 },
              validationRules: "required",
              config: { rows: 3 }
            }
          ]
        }
      ],
      defaultButtons: [],
      buttons: [
        {
          type: "submit",
          class: "btn btn-success",
          text: "<i class='fa fa-save pr-2'></i>Save",
          isVisible: true
        },
        {
          type: "button",
          class: "btn btn-danger",
          text: "<i class='fa fa-close pr-2'></i>Cancel",
          onClick: this.Close,
          isVisible: true
        },
        {
          type: "button",
          class: "btn btn-danger",
          text: "<i class='fa fa-trash pr-2'></i>Delete",
          onClick: this.deleteBooking,
          isVisible: false
        }
      ],
      userName:'',
      DepartmentName:'',
      BookingID:0,  
      UserType:'',
      weekDays: [],
      monthDays: [],
      calendarDays: [],
      currentYear: null,
      currentMonth: null,
      selectedWorkingDays :''
    };
  },
   mounted() {
    // store a deep copy of default buttons
    this.defaultButtons = JSON.parse(JSON.stringify(this.buttons));
  },
  async created() {
    debugger
    var vm = this;
    vm.isLoading=true;
    vm.userName=vm.CellData.user.userName;
    vm.UserType=vm.GetUserInfo.UserType;
    vm.applyUserTypeRules();
    vm.DepartmentName=vm.CellData.user.departmentName;
    await vm.FetchProjectTaskData();
    if (vm.CellData.Mtype != 'Create') {
          vm.isLoading=true;
          vm.FormSchema[0].Data[0].disabled=true,
          vm.FormSchema[0].Data[1].disabled=true,
          vm.buttons[2].isVisible = true;
          vm.EditDetail(vm.CellData); }
          vm.isLoading=false;
      },
  methods: {
  onDayClick(dayObj) {
  if (!dayObj) return
  let days = this.selectedWorkingDays ? this.selectedWorkingDays.split(',') : []
  const i = days.indexOf(String(dayObj.day))
  if (i === -1) {
    days.push(dayObj.day)
  } else {
    days.splice(i, 1)
  }
  this.selectedWorkingDays = days.join(',')
  dayObj.selected = !dayObj.selected
},
  isWeekend(day) {
    debugger
    const date = new Date(this.currentYear, this.currentMonth, day);
    const dayOfWeek = date.getDay(); 
    return dayOfWeek === 0 || dayOfWeek === 6;
  },
    applyUserTypeRules() {
      if (this.UserType === "NU") {
        this.buttons[2].isVisible = false; // hide delete
      } else {
        this.buttons[2].isVisible = true;  // show delete
      }
    },
    validateHours() {
      if (parseInt(this.Hours) > 24) {
        this.hoursError = true; 
      } else {
        this.hoursError = false; 
      }
    },
     EditDetail(getBookingDetail) {
      debugger
      var vm = this;
        vm.BookingID=getBookingDetail.booking_id != 0 ? getBookingDetail.booking_id  :0 ;
      var projecData = {
        label: getBookingDetail.project_name,
        value: getBookingDetail.project_id
      };

      var taskData = {
        label: getBookingDetail.task_name,
        value: getBookingDetail.task_Id
      };
      vm.FormSchema[0].Data[0].value = projecData;
      const projectField = vm.FormSchema[0].Data[0];

      const projectSelection = {
        value: projecData.value,
        label: projecData.label,
        config: projectField.config
      };
       vm.onProjectChange(null, projectField, projectSelection);
      vm.FormSchema[0].Data[1].value = taskData;
      vm.FormSchema[0].Data[2].value = getBookingDetail.booking_start_date;
      vm.FormSchema[0].Data[3].value = getBookingDetail.booking_end_date;
      vm.Hours = Math.floor(getBookingDetail.per_day_working_hours / 60);
      if(getBookingDetail.is_change =="1")
      {
        vm.FormSchema[1].Data[0].visibility = false;
        vm.FormSchema[1].Data[1].visibility = true;
        vm.FormSchema[1].Data[2].visibility = true;
        vm.FormSchema[0].Data[4].value = getBookingDetail.is_change;
        vm.startHour=getBookingDetail.specific_start_time;
        vm.endHour=getBookingDetail.specific_stop_time;
        vm.Hours = 0;
      }
      vm.FormSchema[3].Data[1].value = getBookingDetail.description;
      vm.FormSchema[2].Data[1].value = getBookingDetail.task_type;
      vm.FormSchema[3].Data[0].value = getBookingDetail.working_on_off_days ||  'NO';
      vm.isLoading=false;
    },
    async FetchProjectTaskData() {
      var ths = this;
      await DataService.GetProjectTaskData().then((response) => {
        if (response.data.length > 0) {
          var PData = response.data;
          const groupedData = PData.reduce((acc, item) => {
            const projectId = item.projectId;
            if (!acc[projectId]) {
              acc[projectId] = {
                ProjectId: projectId,
                ProjectName: item.projectName || '',
                StartDate: new Date(item.startDate).getTime(),
                EndDate: new Date(item.endDate).getTime(),
                IsAllowed: item.isAllowed || false,
                TaskList: []
              };
            }
            acc[projectId].TaskList.push({
              StartDate: item.tStartDate ? new Date(item.tStartDate).getTime() : 0,
              EndDate: item.tEndDate ? new Date(item.tEndDate).getTime() : 0,
              TaskName: item.taskName || '',
              TaskId: item.taskId || ''
            });
            return acc;
          }, {});
          var NewProjectData = Object.values(groupedData);
          NewProjectData.forEach((item) => {
            let obj = {
              name: item.ProjectName,
              value: item.ProjectId,
              TaskList: item.TaskList,
              ProjectstartDate:item.StartDate,
              ProjectendDate:item.EndDate
            };
            ths.FormSchema[0].Data[0].config.options.push(obj);
          });
        }
      });
    },
    formatDateForAPI(date) {
          if (!date) return '';
          const d = new Date(date);
          const year = d.getFullYear();
          const month = String(d.getMonth() + 1).padStart(2, '0');
          const day = String(d.getDate()).padStart(2, '0');
          return `${year}-${month}-${day}`;
      },
    onProjectChange: async function (e, x, y) {
      this.FormSchema[0].Data[1].value=''
      this.tasks = [];
      this.CellData.taskId = '';
      const projectId = y.value;
      const projectData = x.config.OptionsForBind;
      const TaskList = projectData.filter(element => element.value === projectId);
      if (TaskList.length > 0) {
       var StartDate =this.formatDateForAPI(TaskList[0].ProjectstartDate);
       var EndDate = this.formatDateForAPI(TaskList[0].ProjectendDate);
       this.FormSchema[0].Data[2].value=StartDate;
       this.FormSchema[0].Data[2].config.minDate=StartDate;
       this.FormSchema[0].Data[2].config.maxDate=EndDate;
       this.FormSchema[0].Data[3].config.minDate=StartDate;
       this.FormSchema[0].Data[3].config.maxDate=EndDate;
       this.FormSchema[0].Data[3].value=EndDate;
        this.FormSchema[0].Data[1].config.options = TaskList[0].TaskList.map(item => ({
          value: item.TaskId,
          name: item.TaskName
        }));
      }
    },
    getCurrentTime() {
      const now = new Date();
      let hours = now.getHours();
      const minutes = now.getMinutes();
      const period = hours >= 12 ? 'PM' : 'AM';
      hours = hours % 12 || 12;
      const formattedHours = hours < 10 ? '0' + hours : hours;
      const formattedMinutes = minutes < 10 ? '0' + minutes : minutes;
      return {
        hh: String(formattedHours),
        mm: String(formattedMinutes),
        A: period
      };
    },
    OnTimeFiledEnabledChange(event) {
      var vm = this;
      var Choosevalue = vm.FormSchema[0].Data[4].value;
      if (Choosevalue == 1) {
        vm.FormSchema[1].Data[0].visibility = false;
        vm.FormSchema[1].Data[1].visibility = true;
        vm.FormSchema[1].Data[2].visibility = true;
      } else {
        vm.FormSchema[1].Data[0].visibility = true;
        vm.FormSchema[1].Data[1].visibility = false;
        vm.FormSchema[1].Data[2].visibility = false;
      }
    },
    OnWorkDaydEnabledChange(event) {
        const vm = this;
        vm.getCurrentTime();
        const now = new Date();
        vm.currentYear = now.getFullYear();
        vm.currentMonth = now.getMonth();
        vm.currentMonthName = now.toLocaleString("default", { month: "short" });
        vm.weekDays = ["Su", "Mo", "Tu", "We", "Th", "Fr", "Sa"];
        const totalDays = new Date( vm.currentYear, vm.currentMonth + 1,  0).getDate();
        const firstDayIndex = new Date( vm.currentYear, vm.currentMonth, 1).getDay();
        vm.calendarDays = [];

        for (let i = 0; i < firstDayIndex; i++) {
          vm.calendarDays.push(null);
        }
      var  selected=false;
      for (let day = 1; day <= totalDays; day++) {
      vm.calendarDays.push({
        day: day,
        selected: false
      })
    }

      var selectedValue = vm.FormSchema[2].Data[0].value;
      if (selectedValue == 'Yes') {
        vm.FormSchema[3].Data[0].visibility = true;
      } else {
        vm.FormSchema[3].Data[0].visibility = false;
      }
    },
    restrictToNumbers(event) {
      const charCode = event.charCode || event.keyCode;
      if ((charCode < 48 || charCode > 57) && charCode !== 8 && charCode !== 9 && charCode !== 13) {
        event.preventDefault();
      }
    },
    Close() {
      this.$parent.IsCellDeatil = false;
    },
    checkEndMinDate() {
      var vm = this;
      var selectedstartdate = vm.FormSchema[0].Data[2].value;
      vm.FormSchema[0].Data[3].config.minDate = selectedstartdate;
    },
   async OnSubmit() {
    debugger
    var vm = this;
      const result = await vm.$refs.AddTaskOnCell.validateForm.validate();
      if (result && vm.Hours != '') {
        var start_time = '';
        var end_time = '';
        var hours=0;
        var startDateTime='';
        var endDateTime='';
      var BookingId= vm.BookingID != 0 ?vm.BookingID: 0 ;
      var cData = vm.CellData;
      var project = vm.FormSchema[0].Data[0].value;
      var task = vm.FormSchema[0].Data[1].value;
      var from_date = vm.FormSchema[0].Data[2].value;
      var to_date = vm.FormSchema[0].Data[3].value;
      var type = vm.FormSchema[0].Data[4].value;
       hours = Math.floor(Number(vm.Hours) * 60);
      var task_type = vm.FormSchema[2].Data[1].value;
      if(type=="1")
      {
        const today = new Date();
        const date = today.toISOString().split('T')[0];
         start_time = `${String(vm.startHour['hh']).padStart(2, '0')}:${String(vm.startHour['mm']).padStart(2, '0')}`;
         end_time = `${String(vm.endHour['hh']).padStart(2, '0')}:${String(vm.endHour['mm']).padStart(2, '0')}`;
          startDateTime = `${date} ${start_time}:00.000`;
          endDateTime = `${date} ${end_time}:00.000`;  
         hours=0
      }      
      var working_days = vm.FormSchema[2].Data[0].value;  
      var description = vm.FormSchema[3].Data[1].value;
      var uid = cData.userId;
      if(vm.CellData.Mtype == 'Create')
      {
        BookingId=0;
      }
      var obj = {
        booking_id: BookingId,
        resourceId: cData.resource_id,
        userId:cData.userId,
        date: cData.date,
        startDate: from_date,
        is_change:type == "0" ? false : true,
        task_type:task_type ==0 ? false : true,
        endDate: to_date,
        startTime:startDateTime,
        endTime:endDateTime,
        working_day: working_days =="No" ? false : true,
        projectId: project.value,
        projectName: project.label,
        taskId: task.value,
        taskName:task.label,
        hours: hours,
        description: vm.FormSchema[3].Data[1].value,
        bookingType: this.bookingType
      };      
      vm.$emit("saveBooking", obj);
    }
    else
    {
      vm.ShowAlert(vm.$t([vm.$t("MandatoryString")]),"failer",true,vm.$t("Alert"));
      
    }
    },
    async deleteBooking(){
      debugger
      var vueObj = this;
      vueObj.confirmR(vueObj.$t("ConfirmDelete"), true, (vueObj.$t("Delete") + " " + vueObj.$t("Booking")), async function () {
        vueObj.isLoading = true;
          var obj = {
            bookingId:vueObj.CellData.booking_id,
            resourceId:vueObj.CellData.resource_id
          };   
           vueObj.$emit('Delete',obj);
      });
    }
  }
}
</script>

<style>
.vue2-timepicker-wrapper {
  display: flex;
  align-items: center;
}

.vue2-timepicker-wrapper input {
  width: 100%;
  padding: 10px;
  font-size: 1rem;
}

.vue__time-picker-dropdown {
  max-height: 500px !important;
  overflow-y: auto !important;
  z-index: 9999 !important;
}
.error-message {
  font-size: 12px;
  margin-top: 5px;
}
.selected {
  background-color: #96c83a;
  color: white;
}

.empty {
  background-color: #f5f5f5;
}

.disabled {
  background-color: #e0e0e0;
  color: #999;
  pointer-events: none; 
}

/***********/








</style>
